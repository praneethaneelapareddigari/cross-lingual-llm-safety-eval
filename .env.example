# Copy to .env and fill in. Never commit the real .env file.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TOGETHER_API_KEY=        # hosts Llama, Gemma, Qwen open-weight endpoints
HF_API_TOKEN=            # optional fallback for open-weight models via HF Inference

# Judge model (used to score harmfulness/refusal) — recommend a different
# provider than any model under test, to avoid self-preferencing bias
JUDGE_MODEL_PROVIDER=anthropic
JUDGE_MODEL_NAME=claude-sonnet-4-6
